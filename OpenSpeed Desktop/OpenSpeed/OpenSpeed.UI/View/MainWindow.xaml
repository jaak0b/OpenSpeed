<Window x:Class="OpenSpeed.UI.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenSpeed"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:ip="clr-namespace:IPUserControls;assembly=IPUserControls.Wpf"
        xmlns:viewModel="clr-namespace:OpenSpeed.UI.ViewModel"
        xmlns:ipUserControls="clr-namespace:IPUserControls;assembly=IPUserControls"
        xmlns:converter="clr-namespace:OpenSpeed.UI.Converter"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:oxyPlot="clr-namespace:OxyPlot;assembly=OxyPlot"
        xmlns:series="clr-namespace:OxyPlot.Series;assembly=OxyPlot"
        xmlns:componentModel="clr-namespace:System.ComponentModel;assembly=WindowsBase"
        xmlns:calcBinding="clr-namespace:CalcBinding;assembly=CalcBinding"
        xmlns:markupExtensions="clr-namespace:OpenSpeed.UI.MarkupExtensions"
        xmlns:models="clr-namespace:OpenSpeed.Core.Models;assembly=OpenSpeed.Core"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance viewModel:MainWindowViewModel}"
        Title="OpenSpeed" Height="660" Width="1050" MinHeight="550" MinWidth="900"
        WindowStyle="None" ResizeMode="CanResize">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48" ResizeBorderThickness="6"
                            GlassFrameThickness="0" CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <converter:BoolToConnectionStatusConverter x:Key="BoolToConnectionStatusConverter"/>
        <CollectionViewSource Source="{Binding Steps}" x:Key="StepsViewSource">
            <CollectionViewSource.SortDescriptions>
                <componentModel:SortDescription PropertyName="SpeedStep"/>
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="OpenSpeed" Foreground="White" FontSize="18"
                           FontWeight="Bold" VerticalAlignment="Center" Margin="16,0"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Stretch">
                    <TextBlock Text="{markupExtensions:Loc Language}" Foreground="#CBD5E0"
                               VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                    <ComboBox Width="120" VerticalAlignment="Center"
                              shell:WindowChrome.IsHitTestVisibleInChrome="True"
                              ItemsSource="{markupExtensions:EnumValues EnumType=models:Language}"
                              SelectedItem="{Binding SelectedLanguage}"
                              Padding="6,3" VerticalContentAlignment="Center"/>

                    <Button x:Name="ButtonMinimize" Content="&#xE921;" Margin="12,0,0,0"
                            Style="{StaticResource CaptionButton}"
                            ToolTip="{markupExtensions:Loc TtMinimize}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="Minimize_OnClick"/>
                    <Button x:Name="ButtonMaximize" Content="&#xE922;"
                            Style="{StaticResource CaptionButton}"
                            ToolTip="{markupExtensions:Loc TtMaximize}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="MaximizeRestore_OnClick"/>
                    <Button x:Name="ButtonClose" Content="&#xE8BB;"
                            Style="{StaticResource CaptionCloseButton}"
                            ToolTip="{markupExtensions:Loc TtClose}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="Close_OnClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,4,0,0">
                <StackPanel>

                    <Border Style="{StaticResource CardSection}">
                        <StackPanel>
                            <TextBlock Text="{markupExtensions:Loc Connection}" Style="{StaticResource SectionHeader}"/>

                            <TextBlock Text="{markupExtensions:Loc Z21Address}" Style="{StaticResource FieldLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ipUserControls:IpField Grid.Column="0" HorizontalAlignment="Left"
                                    IpAddress="{Binding EndPointConfiguration.Z21IpAddress}"
                                    IsEnabled="{calcBinding:Binding !AnyMeasurementInProgress}"/>
                                <ipUserControls:IpStatus Grid.Column="1"
                                    ConnectionStatus="{Binding Z21Connected, Converter={StaticResource BoolToConnectionStatusConverter}}"
                                    Margin="4,0,0,0" VerticalContentAlignment="Center"/>
                            </Grid>

                            <TextBlock Text="{markupExtensions:Loc SensorAddress}" Style="{StaticResource FieldLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ipUserControls:IpField Grid.Column="0" HorizontalAlignment="Left"
                                    IpAddress="{Binding EndPointConfiguration.SpeedSensorIpAddress}"
                                    IsEnabled="{calcBinding:Binding !AnyMeasurementInProgress}"/>
                                <ipUserControls:IpStatus Grid.Column="1"
                                    ConnectionStatus="{Binding SpeedSensorConnected, Converter={StaticResource BoolToConnectionStatusConverter}}"
                                    Margin="4,0,0,0" VerticalContentAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardSection}">
                        <StackPanel>
                            <TextBlock Text="{markupExtensions:Loc Locomotive}" Style="{StaticResource SectionHeader}"/>

                            <TextBlock Text="{markupExtensions:Loc DecoderAddress}" Style="{StaticResource FieldLabel}"/>
                            <xctk:IntegerUpDown Value="{Binding LocomotiveConfiguration.DecoderAddress}"
                                Minimum="0" Padding="5"
                                IsEnabled="{calcBinding:Binding !AnyMeasurementInProgress}"/>

                            <TextBlock Text="{markupExtensions:Loc DccSpeedMode}" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{markupExtensions:EnumValues EnumType=models:DccSpeedMode}"
                                      SelectedItem="{Binding LocomotiveConfiguration.DccSpeedMode}"
                                      Padding="5,4"
                                      IsEnabled="{calcBinding:Binding !AnyMeasurementInProgress}"/>

                            <TextBlock Text="{markupExtensions:Loc Scale}" Style="{StaticResource FieldLabel}"/>
                            <xctk:IntegerUpDown Value="{Binding LocomotiveConfiguration.LocomotiveScale}"
                                Minimum="1" Padding="5"
                                IsEnabled="{calcBinding:Binding !AnyMeasurementInProgress}"/>
                        </StackPanel>
                    </Border>

                    <TabControl Margin="8,4">
                        <TabItem Header="{markupExtensions:Loc TabSpeed}">
                            <Border Style="{StaticResource CardSection}" Margin="0,8,0,4">
                                <StackPanel>
                                    <TextBlock Text="{markupExtensions:Loc MaxSpeed}" Style="{StaticResource FieldLabel}"/>
                                    <xctk:IntegerUpDown Value="{Binding MeasurementConfiguration.MaxSpeed}"
                                        Minimum="1" Padding="5"
                                        IsEnabled="{calcBinding:Binding !AnyMeasurementInProgress}"/>

                                    <TextBlock Text="{markupExtensions:Loc SpeedStepInterval}" Style="{StaticResource FieldLabel}"/>
                                    <xctk:IntegerUpDown Value="{Binding MeasurementConfiguration.SpeedStepInterval}"
                                        Minimum="1" Padding="5"
                                        IsEnabled="{calcBinding:Binding !AnyMeasurementInProgress}"/>

                                    <TextBlock Text="{markupExtensions:Loc StartingSpeedStep}" Style="{StaticResource FieldLabel}"/>
                                    <xctk:IntegerUpDown Value="{Binding MeasurementConfiguration.StartingSpeedStep}"
                                        Minimum="1" Padding="5"
                                        IsEnabled="{calcBinding:Binding !AnyMeasurementInProgress}"/>

                                    <TextBlock Text="{markupExtensions:Loc Results}" Style="{StaticResource SectionHeader}" Margin="0,12,0,8"/>
                                    <DataGrid ItemsSource="{Binding Source={StaticResource StepsViewSource}}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False" CanUserDeleteRows="False"
                                              IsReadOnly="True" MaxHeight="200"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto"
                                              EnableRowVirtualization="True"
                                              ScrollViewer.CanContentScroll="True"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              VirtualizingPanel.VirtualizationMode="Standard"
                                              VirtualizingPanel.IsVirtualizingWhenGrouping="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Binding="{Binding SpeedStep}"    Header="{markupExtensions:Loc ColStep}"     Width="*"/>
                                            <DataGridTextColumn Binding="{Binding ForwardPass}"  Header="{markupExtensions:Loc ColForward}"  Width="*"/>
                                            <DataGridTextColumn Binding="{Binding BackwardPass}" Header="{markupExtensions:Loc ColBackward}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <Button Name="ButtonExport"
                                            Content="{markupExtensions:Loc BtnExport}" Margin="0,12,0,0"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="ButtonExport_OnClick"
                                            IsEnabled="{calcBinding:Binding 'Steps.Count &gt; 0 and !AnyMeasurementInProgress'}"/>

                                    <Button Name="ButtonStartMeasurement"
                                            Content="{markupExtensions:Loc BtnStartSpeed}" Margin="0,12,0,0"
                                            Style="{StaticResource PrimaryButton}"
                                            Click="ButtonStartMeasurement_OnClick"
                                            Visibility="{calcBinding:Binding !MeasurementInProgress}"
                                            IsEnabled="{calcBinding:Binding 'Z21Connected and SpeedSensorConnected'}"/>
                                    <Button Name="ButtonCancelMeasurement"
                                            Content="{markupExtensions:Loc BtnCancel}" Margin="0,12,0,0"
                                            Style="{StaticResource DangerButton}"
                                            Click="ButtonCancelMeasurement_OnClick"
                                            Visibility="{calcBinding:Binding MeasurementInProgress}"/>
                                </StackPanel>
                            </Border>
                        </TabItem>

                        <TabItem Header="{markupExtensions:Loc TabLength}">
                            <Border Style="{StaticResource CardSection}" Margin="0,8,0,4">
                                <StackPanel>
                                    <TextBlock Text="{markupExtensions:Loc SpeedStep}" Style="{StaticResource FieldLabel}"/>
                                    <xctk:IntegerUpDown Value="{Binding LengthMeasurementConfiguration.SpeedStep}"
                                        Minimum="1" Padding="5"
                                        IsEnabled="{calcBinding:Binding !AnyMeasurementInProgress}"/>

                                    <Border Margin="0,12,0,0" Padding="10,8" CornerRadius="6"
                                            Background="#F0FFF4" BorderBrush="#C6F6D5" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{markupExtensions:Loc LengthLabel}" Foreground="#276749" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding TrainLengthDisplay}"
                                                       Foreground="#276749" FontWeight="Bold" FontSize="15"/>
                                        </StackPanel>
                                    </Border>

                                    <Button Name="ButtonStartLengthMeasurement"
                                            Content="{markupExtensions:Loc BtnMeasureLength}" Margin="0,12,0,0"
                                            Style="{StaticResource GreenButton}"
                                            Click="ButtonStartLengthMeasurement_OnClick"
                                            Visibility="{calcBinding:Binding !LengthMeasurementInProgress}"
                                            IsEnabled="{calcBinding:Binding 'Z21Connected and SpeedSensorConnected and !MeasurementInProgress'}"/>
                                    <Button Name="ButtonCancelLengthMeasurement"
                                            Content="{markupExtensions:Loc BtnCancelLength}" Margin="0,12,0,0"
                                            Style="{StaticResource DangerButton}"
                                            Click="ButtonCancelLengthMeasurement_OnClick"
                                            Visibility="{calcBinding:Binding LengthMeasurementInProgress}"/>
                                </StackPanel>
                            </Border>
                        </TabItem>
                    </TabControl>

                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="1" Margin="8" Background="White" CornerRadius="8"
                    Effect="{StaticResource CardShadow}">
                <oxy:PlotView x:Name="Plot" Model="{Binding PlotViewModel.Plot}"/>
            </Border>

        </Grid>
    </Grid>
</Window>
